{
  "name": "aylett.co.uk",
  "author": "@andrewaylett",
  "license": "Apache-2.0",
  "repository": "https://github.com/andrewaylett/aylett.co.uk",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --experimental-app-only",
    "start": "next start",
    "postinstall": "pnpm typegen",
    "format": "pnpm run lint --fix",
    "typegen": "next typegen",
    "posttypecheck": "pnpm run react-compiler",
    "typecheck": "tsc -b .",
    "prelint": "pnpm install --frozen-lockfile",
    "postlint": "pnpm run typecheck",
    "lint": "eslint",
    "pretest": "pnpm run lint",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules --experimental-print-required-tla\" jest",
    "react-compiler": "react-compiler-marker ."
  },
  "dependencies": {
    "client-only": "0.0.1",
    "date-fns": "4.1.0",
    "html-to-image": "1.11.13",
    "immer": "11.1.4",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-to-markdown": "2.1.2",
    "mermaid": "11.14.0",
    "micromark-util-types": "2.0.2",
    "next": "16.2.3",
    "next-plausible": "4.0.0",
    "nlcst-to-string": "4.0.0",
    "parse-english": "7.0.0",
    "react": "19.2.4",
    "react-is": "19.2.4",
    "recharts": "3.8.1",
    "rehype-format": "5.0.1",
    "rehype-react": "8.0.0",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "remark-stringify": "11.0.0",
    "retext-smartypants": "6.2.0",
    "rss": "1.2.2",
    "server-only": "0.0.1",
    "temporal-polyfill": "0.3.2",
    "to-vfile": "8.0.0",
    "unified": "11.0.5",
    "unist-util-is": "6.0.1",
    "unist-util-visit": "5.1.0",
    "unist-util-visit-parents": "6.0.2",
    "vfile": "6.0.3",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@jest/globals": "30.3.0",
    "@next/eslint-plugin-next": "16.2.3",
    "@prettier/plugin-xml": "3.4.2",
    "@swc/jest": "0.2.39",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/hast": "3.0.4",
    "@types/jest": "30.0.0",
    "@types/mdast": "4.0.4",
    "@types/nlcst": "2.0.3",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/rss": "0.0.32",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "2.10.19",
    "browserslist": "4.28.2",
    "caniuse-lite": "1.0.30001788",
    "encoding": "0.1.13",
    "eslint": "9.39.4",
    "eslint-config-andrewaylett": "7.0.0",
    "eslint-config-next": "16.2.3",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "expect": "30.3.0",
    "glob": "13.0.6",
    "globals": "17.5.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jiti": "2.6.1",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "react-compiler-marker": "0.1.0",
    "tailwindcss": "4.2.2",
    "ts-jest": "29.4.9",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2"
  },
  "pnpm": {
    "overrides": {
      "jsdom": "$jsdom",
      "react": "$react",
      "react-dom": "$react",
      "react-is": "$react",
      "next-plausible>next": "$next",
      "glob": "$glob",
      "eslint-import-resolver-typescript": "$eslint-import-resolver-typescript"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ]
  },
  "browserslist": [
    "defaults",
    "> 0.5% in GB and not dead",
    "current node"
  ],
  "engines": {
    "node": "^24.0.0"
  },
  "engineStrict": true
}
